# shortlist instructors with high or low z score counts (does not perform a metric cutoff)
def shortlist(dict, direction, z_score_cutoff, flag_percentage):
    shortlist = []
    for i in dict.keys():
        count = 0
        item = dict[i]
        for j in item:
            if direction == "high": 
                if j>=z_score_cutoff:
                    count+=1
            elif direction == "low": 
                if j<=-z_score_cutoff:
                    count+=1
        if (100*(count/len(item)) > flag_percentage):
            shortlist.append(i)
    return shortlist

